&lt;figure&gt;
&lt;p&gt;&lt;img src="https://www.dailyremu.com/posts/2021-07-25-3%EA%B8%B0%EC%8B%A0%EB%8F%84%EC%8B%9C-%EC%82%AC%EC%A0%84-%EC%B2%AD%EC%95%BD-%EB%B0%8F-%EA%B3%B5%EA%B3%B5%EB%B6%84%EC%96%91-%EB%82%98%EC%9D%98-%EC%86%8C%EB%93%9D%EA%B8%B0%EC%A4%80-%EC%9E%90%EC%82%B0/images/%EC%9E%90%EC%82%B03.jpg"
